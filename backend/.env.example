# Database
DATABASE_URL=postgresql://user:password@localhost:5432/eduhub
DB_SSL=false

# Frontend URL for reset links
FRONTEND_BASE_URL=http://localhost:8080

# Auth email provider: dev | sendgrid | resend
EMAIL_PROVIDER=dev
EMAIL_FROM=no-reply@eduhub.local

# Set one of these based on EMAIL_PROVIDER
SENDGRID_API_KEY=
RESEND_API_KEY=

# Optional: expose debug OTP/reset link fields in API responses (non-production default: true)
EXPOSE_AUTH_DEBUG=true
